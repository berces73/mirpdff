{
  "name": "mirpdf",
  "version": "1.0.0",
  "description": "MirPDF — Türkçe ücretsiz PDF araçları (Cloudflare Pages + Worker)",
  "private": true,
  "dependencies": {
    "stripe": "^20.3.1",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.2"
  },
  "scripts": {
    "build": "npm run build:seo && npm run build:content",
    "build:seo": "node scripts/generate-seo-pages.js",
    "build:content": "node scripts/build-content.js",
    "deploy:pages": "wrangler pages deploy public --project-name mirpdf",
    "deploy:worker": "wrangler deploy --config wrangler.worker.toml",
    "deploy": "npm run deploy:worker && npm run deploy:pages",
    "gate": "bash scripts/release_gate.sh",
    "smoke": "bash scripts/smoke-test.sh",
    "release": "bash scripts/release_gate.sh && npm run deploy && bash scripts/smoke-test.sh",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "lint:html": "node scripts/head-quality.js"
  },
  "devDependencies": {}
}
