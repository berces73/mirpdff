# ============================================================
# MirPDF Processor — .env
# Bu dosyayı .env olarak kopyala, gerçek değerleri doldur.
# ============================================================

# Dinlenecek port (Nginx arkasında, sadece localhost'a bağla)
PORT=3001

# Cloudflare Worker URL'i (download/upload/callback için)
WORKER_URL=https://mirpdf.com

# Worker ↔ Processor ortak secret (wrangler secret put PROCESSOR_SECRET ile aynı)
# Üretmek için: openssl rand -hex 32
PROCESSOR_SECRET=BURAYA_GERCEK_SECRET_YAZ

# Maksimum eşzamanlı işlem (VPS RAM'ine göre ayarla)
# CX22 (4GB): 2  |  CX32 (8GB): 4
PROC_MAX_CONCURRENCY=2

# Dosya boyutu limiti (byte) — 50MB
PROC_MAX_BYTES=52428800

# Araç zaman aşımı (ms)
PROC_TIMEOUT_MS=180000
PROC_COMPRESS_TIMEOUT_MS=90000
PROC_WORD_TIMEOUT_MS=120000
PROC_OCR_TIMEOUT_MS=180000

# OCR ayarları
PROC_OCR_MAX_PAGES=50
PROC_OCR_DPI=200

# Geçici dosya dizini
TMP_DIR=/tmp

# Log seviyesi: debug | info | warn | error
LOG_LEVEL=info

# İkili araçların path'i (genellikle değiştirmene gerek yok)
# GS_BIN=gs
# LO_BIN=libreoffice
# TESS_BIN=tesseract

# Unlock (qpdf + ghostscript)
PROC_UNLOCK_TIMEOUT_MS=60000
# PROC_QPDF_BIN=qpdf
